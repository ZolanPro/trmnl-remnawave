<div class="layout layout--col gap--medium">
    <div class="grid grid--cols-3 portrait:grid--cols-2 gap--medium h--full">
        <div class="metric flex flex--col flex--center-x flex--center-y gap--xsmall p--4 text--center h--full">
            <span class="label 1bit:text--black">Traffic Today</span>
            <span class="value value--large portrait:value--medium">{{ IDX_1.response.bandwidthLastTwoDays.current }}</span>
            <span class="description">Last 24h</span>
        </div>

        <div class="metric flex flex--col flex--center-x flex--center-y gap--xsmall p--4 text--center h--full">
            <span class="label 1bit:text--black">Traffic 7 Days</span>
            <span class="value value--large portrait:value--medium">{{ IDX_1.response.bandwidthLastSevenDays.current }}</span>
            <span class="description">Last week</span>
        </div>

        <div class="metric flex flex--col flex--center-x flex--center-y gap--xsmall p--4 text--center h--full portrait:col--span-2">
            <span class="label 1bit:text--black">Traffic 30 Days</span>
            <span class="value value--large portrait:value--medium">{{ IDX_1.response.bandwidthLast30Days.current }}</span>
            <span class="description">Last month</span>
        </div>
    </div>

    <div class="grid grid--cols-3 portrait:grid--cols-2 gap--medium h--full">
        <div class="metric flex flex--col flex--center-x flex--center-y gap--xsmall p--4 text--center h--full">
            <span class="label 1bit:text--black">Nodes</span>
            <span class="value value--large portrait:value--medium">{{ active_nodes }} / {{ IDX_2.response.size }}</span>
            <span class="description">Active / total</span>
        </div>

        <div class="metric flex flex--col flex--center-x flex--center-y gap--xsmall p--4 text--center h--full">
            <span class="label 1bit:text--black">Users</span>
            <span class="value value--large portrait:value--medium">{{ IDX_0.response.users.statusCounts.ACTIVE }} / {{ IDX_0.response.users.totalUsers }}</span>
            <span class="description">Active / total</span>
        </div>

        <div class="metric flex flex--col flex--center-x flex--center-y gap--xsmall p--4 text--center h--full portrait:col--span-2">
            <span class="label 1bit:text--black">Online Now</span>
            <span class="value value--large portrait:value--medium">{{ IDX_0.response.onlineStats.onlineNow }}</span>
            <span class="description">Connected</span>
        </div>
    </div>
</div>
